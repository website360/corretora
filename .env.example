# ─────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Corretora SaaS"

# Feature flag: when true the UI runs entirely on mocked data and
# does not require a live Supabase connection (great for previews).
NEXT_PUBLIC_USE_MOCKS=true

# ─────────────────────────────────────────────────────────────
# Chaves de plataforma — SERVER ONLY
#
# As variáveis abaixo (Resend e Asaas) também podem ser definidas pelo
# super-admin em /admin → aba "Sistema". O valor salvo lá SOBRESCREVE o que
# estiver aqui; estas ficam como fallback.
# ─────────────────────────────────────────────────────────────

# E-mail transacional (Resend)
# Chave de API do Resend (https://resend.com/api-keys).
RESEND_API_KEY=re_your_api_key
# Remetente verificado no Resend. Use um domínio verificado em produção;
# para testes, o Resend aceita "onboarding@resend.dev".
EMAIL_FROM="Corretora SaaS <onboarding@resend.dev>"
# Opcional: endereço de resposta exibido ao destinatário.
EMAIL_REPLY_TO=

# Pagamentos (Asaas)
ASAAS_API_KEY=your-asaas-api-key
# Sandbox por padrão; em produção use https://api.asaas.com/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Token compartilhado para validar o webhook do Asaas.
ASAAS_WEBHOOK_TOKEN=your-asaas-webhook-token
